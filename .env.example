# Environment Variables for FrenchDubLenpse

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# Upload Settings
# ============================================
MAX_UPLOAD_SIZE=500  # MB
UPLOAD_FOLDER=./static/uploads
TEMP_FOLDER=./temp
OUTPUT_FOLDER=./static/outputs

# ============================================
# Whisper (Speech-to-Text)
# ============================================
# Options: tiny, base, small, medium, large
# tiny: ~39MB, fast
# base: ~140MB, recommended
# small: ~466MB, better quality
WHISPER_MODEL=base

# ============================================
# Traduction (Translation)
# ============================================
# Options: google, mymemory
# google: Requires Google Cloud API key (paid)
# mymemory: Free, no API key needed
TRANSLATION_PROVIDER=mymemory
TARGET_LANGUAGE=fr

# ============================================
# Google Cloud (Optional - for Google Translate)
# ============================================
GOOGLE_API_KEY=your-google-cloud-api-key
GOOGLE_CLOUD_PROJECT=your-project-id

# ============================================
# TTS (Text-to-Speech)
# ============================================
# Options: gtts (free), elevenlabs (premium)
# gtts: Free, Google Text-to-Speech
# elevenlabs: Premium, better quality
TTS_PROVIDER=gtts
TTS_LANGUAGE=fr
TTS_SPEED=1.0

# ============================================
# ElevenLabs (Optional - for Premium TTS)
# ============================================
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ============================================
# FFmpeg Paths
# ============================================
# Usually auto-detected, only set if needed
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ============================================
# Server Settings
# ============================================
HOST=0.0.0.0
PORT=5000
